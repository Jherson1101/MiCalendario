<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar Actividad"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary"
            android:layout_marginBottom="30dp"/>

        <EditText
            android:id="@+id/etTituloEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Título"/>

        <EditText
            android:id="@+id/etDescripcionEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descripción"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etHoraEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hora"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etPeriodoEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Periodo"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btnActualizarTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Actualizar Actividad"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue_primary"
            android:layout_marginTop="30dp"/>

    </LinearLayout>
</ScrollView>